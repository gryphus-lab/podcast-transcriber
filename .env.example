# Copy this file to .env and fill in your own values.
# .env is git-ignored and is specific to your user/instance.

# HuggingFace token (required for speaker diarization)
# Get one at: https://huggingface.co/settings/tokens
# Accept model terms at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Whisper model size: tiny, base, small, medium, large-v3
# large-v3 is most accurate but slowest; medium is a good balance
WHISPER_MODEL=large-v3

# Default language (ISO 639-1 code, e.g. en, de, fr)
LANGUAGE=en

# Output directory for transcripts
OUTPUT_DIR=output
